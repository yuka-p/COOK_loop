<div class="max-w-md mx-auto mt-6 px-3 sm:px-0 page-fade">
  <% if @my_menus.blank? %>
    <div class="text-center mt-10 space-y-4">
      <p class="text-sm text-base-content/70">
        まずは下の『マイメニュー』ボタンより、<br>
        よく作る料理を登録してみましょう 🍳
      </p>
    </div>
  <% elsif @meal_items.blank? %>
    <div class="text-center mt-10 space-y-4">
      <p class="text-sm text-base-content/70">
        今日はどんな献立にしますか？ 📅
      </p>
    </div>
  <% else %>
    <div class="flex justify-between mb-4 sm:mb-6 max-w-md mx-auto">
      <button type="button" id="toggle-meal-plan"
              class="btn btn-xs sm:btn-sm btn-outline ml-auto">
        献立を非表示
      </button>
    </div>
    <div id="meal-plan-area" class="w-full home-section home-delay-1">
      <%= form_with url: bulk_update_meal_items_path, method: :patch, local: true do %>
        <div class="card bg-base-100 shadow-md rounded-2xl home-child child-1">
          <div class="card-body px-4 py-5 sm:px-5 sm:py-6">
            <% @meal_items
               .sort_by { |genre, _| MyMenu.genres[genre] }
               .each do |genre, items| %>
              <% next if items.blank? %>
              <div class="mb-6 sm:mb-8">
                <h3 class="text-xs sm:text-sm font-semibold mb-3
                        border-l-4
                        px-3 py-1 sm:px-4 sm:py-1.5 rounded-md tracking-wide
                        <%= genre_heading_class(genre) %>">
                  <%= MyMenu.genres_i18n[genre] %>
                </h3>
                <ul class="space-y-1">
                  <% items.each do |meal_item| %>
                    <li class="flex items-center gap-2 sm:gap-3 px-2 py-1.5 sm:px-3 sm:py-2 rounded-lg
                               hover:bg-base-200 transition">
                      <%= check_box_tag "meal_item_ids[]",
                                         meal_item.id,
                                         false,
                                         class: "checkbox checkbox-sm sm:checkbox-md check-pop" %>
                      <div class="flex-1">
                        <p class="text-sm sm:text-base">
                          <%= meal_item.my_menu.title %>
                        </p>
                      </div>
                    </li>
                  <% end %>
                </ul>
              </div>
            <% end %>
            <div class="flex justify-end gap-2 sm:gap-3 mt-4 sm:mt-6">
              <%= button_tag "作成完了",
                type: :submit,
                name: "commit_action",
                value: "mark_as_cooked",
                class: "action-primary btn-sm sm:btn-md btn-pop"
              %>
              <%= button_tag "削除",
                type: :submit,
                name: "commit_action",
                value: "remove_from_plan",
                class: "btn btn-sm sm:btn-md btn-outline btn-error" 
              %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
  <!-- ▼ おすすめメニュー -->
  <div class="max-w-md mx-auto mt-8 sm:mt-10 home-section home-delay-2">
    <% if @recommended_menus.present? %>
      <div class="relative mb-4 sm:mb-6">
        <%= link_to root_path,
          class: "refresh-btn absolute right-0 top-1/2 -translate-y-1/2 z-10 inline-block
                  transition hover:scale-110 active:scale-95" do %>
          <%= image_tag "refresh.png", class: "w-10 h-8 sm:w-14 sm:h-10" %>
        <% end %>
        <div class="recommended-title text-xs sm:text-sm">
          <p>RECOMMENDED MENU</p>
        </div>
      </div>
    </div>
    <div class="space-y-3 home-child child-1">
      <% @recommended_menus.each do |menu| %>
        <div class="rounded-full shadow-sm mx-auto border-4 sm:border-8 home-child child-2
                    w-full max-w-[260px] sm:max-w-[300px]"
             style="background-color:#fffaf0; border-color:<%= genre_card_border_color(menu) %>;">
          <div class="flex items-center py-1.5 px-4 sm:py-2 sm:px-3">
            <span class="flex-1 text-center text-sm sm:text-base font-semibold truncate">
              <%= menu.title %>
            </span>
            <%= button_to "＋",
                  add_meal_item_my_menu_path(menu),
                  method: :post,
                  class: "btn btn-xs sm:btn-sm btn-circle ml-2 shadow-none text-lg",
                          style: "background-color:#ad9d8a; border:none; color:white;" %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
<div class="flex justify-center gap-3 sm:gap-8 mt-10 relative home-section home-delay-3">
  <div class="home-child child-1">
    <%= link_to my_menus_path,
        class: "round-action-card w-32 h-32 sm:w-44 sm:h-44 flex flex-col items-center justify-center gap-2" do %>
      <%= image_tag "my_menu.png", class: "w-14 h-14 sm:w-20 sm:h-20 object-contain" %>
      <span class="text-[12px] sm:text-sm font-semibold tracking-wide">
        マイメニュー
      </span>
    <% end %>
  </div>
  <div class="home-child child-2">
    <%= link_to new_meal_plan_path,
        class: "round-action-card w-32 h-32 sm:w-44 sm:h-44 flex flex-col items-center justify-center gap-2" do %>
      <%= image_tag "meal_plan.png", class: "w-14 h-14 sm:w-20 sm:h-20 object-contain" %>
      <span class="text-[12px] sm:text-sm font-semibold tracking-wide">
        献立をつくる
      </span>
    <% end %>
  </div>
  <div class="home-child child-3">
    <%= link_to recipes_path, 
        class: "round-action-card w-32 h-32 sm:w-44 sm:h-44 flex flex-col items-center justify-center gap-2" do %>
      <%= image_tag "search_recipe.png", class: "w-14 h-14 sm:w-20 sm:h-20 object-contain" %>
      <span class="text-[12px] sm:text-sm font-semibold tracking-wide">
        レシピをさがす
      </span>
    <% end %>
  </div>
</div>
<div class="flex justify-center items-center gap-6 mt-12 mb-8 home-section home-delay-3">
  <%= link_to "https://twitter.com/share?url=#{CGI.escape('https://cook-loop.com/')}&text=#{CGI.escape('献立サポートアプリ🍴COOK loop🥘 毎日の献立を、もっと楽に。')}", 
        target: '_blank', rel: 'noopener noreferrer', 
        class: "group flex flex-col items-center gap-2 transition-transform hover:scale-110" do %>
    <div class="w-12 h-12 bg-white rounded-full shadow-sm flex items-center justify-center border border-gray-100 group-hover:shadow-md transition-shadow">
      <%= image_tag 'x-logo.png', alt: 'Xでシェア', class: "w-5 h-5 object-contain" %>
    </div>
    <span class="text-[10px] text-gray-500 font-medium tracking-wider">SHARE</span>
  <% end %>
  <%= link_to "https://social-plugins.line.me/lineit/share?url=#{CGI.escape('https://cook-loop.com/')}", 
        target: '_blank', rel: 'noopener noreferrer', 
        class: "group flex flex-col items-center gap-2 transition-transform hover:scale-110" do %>
    <div class="w-12 h-12 bg-white rounded-full shadow-sm flex items-center justify-center border border-gray-100 group-hover:shadow-md transition-shadow">
      <%= image_tag 'line-logo.png', alt: 'LINEで送る', class: "w-6 h-6 object-contain" %>
    </div>
    <span class="text-[10px] text-gray-500 font-medium tracking-wider">LINE</span>
  <% end %>
</div>
</div>
