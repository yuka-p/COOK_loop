<% content_for :title, "献立作成" %>
<div data-controller="meal-plans-new" class="max-w-3xl mx-auto mt-8 space-y-6">
  <div class="card bg-base-100 shadow px-8 py-4 max-w-2xl mx-auto page-section page-delay-1">
    <div class="max-w-4xl mx-auto space-y-4">
      <div class="flex flex-col md:flex-row md:items-center gap-4">
        <div class="flex-1">
          <div id="genreFilters" class="flex gap-2 flex-wrap">
            <button class="btn btn-sm genre-filter-button bg-[#bebbf7]/40 text-gray-700 border border-[#bebbf7] hover:bg-[#bebbf7]/60" data-genre="all" type="button">
              すべて
            </button>
            <% MyMenu.genres.keys.each do |genre| %>
              <button class="btn btn-sm genre-filter-button <%= genre_button_class(genre) %>" data-genre="<%= genre %>" type="button">
                <%= MyMenu.genres_i18n[genre] %>
                <span id="count-<%= genre %>" class="ml-1 hidden text-xs font-bold bg-primary text-white rounded-full px-1.5"></span>
              </button>
            <% end %>
          </div>
        </div>
        <div class="w-full md:w-56">
          <%= select_tag :sort,
            options_for_select(
              [
                ["最近作っていない順", "last_cooked_desc"],
                ["新しい順", "created_desc"],
                ["50音順", "title_asc"],
              ],
              params[:sort]
            ),
           { class: "select select-bordered w-full js-sort-select", id: "sortSelect" }
           %>
        </div>
      </div>
      <% if @tags.present? %>
        <div id="tagFilters" class="flex gap-2 flex-wrap">
          <% @tags.each do |tag| %>
            <button type="button" class="tag-filter-button" data-tag-id="<%= tag.id %>">
              <%= tag.name %>
            </button>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
  <%= form_with url: confirm_meal_plans_path, method: :post, data: { turbo_frame: "modal" } do |f| %>
    <div class="max-w-md mx-auto px-4 mb-8 page-section page-delay-2">
      <div class="relative">
        <%= f.text_field :keyword,
              value: params[:keyword],
              placeholder: "メニュー名で検索",
              class: "input w-full rounded-full border border-gray-200 bg-white focus:border-[#98b3a0] focus:outline-none transition-all pl-6 pr-24 py-6 text-gray-600 shadow-sm",
              style: "font-size: 16px;" %>
        <%= f.submit "検索",
              class: "absolute right-1.5 top-1/2 -translate-y-1/2 btn rounded-full border-none text-white px-6 h-[calc(100%-12px)] min-h-0 z-10",
              style: "background-color: #98b3a0; font-size: 14px;" %>
      </div>
    </div>
    <div class="bg-[#faf0e6] p-4 sm:p-8 rounded-2xl my-6 page-section page-delay-2">
      <div id="menuList" class="flex flex-wrap gap-3 justify-start page-section page-delay-3">
        <% @my_menus.each do |menu| %>
          <label class="group menu-item relative block cursor-pointer" 
                 data-genre="<%= menu.genre %>" 
                 data-tags="<%= menu.tags.pluck(:id).join(',') %>"
                 data-created="<%= menu.created_at.to_i %>"
                 data-last-cooked="<%= menu.last_cooked_at ? menu.last_cooked_at.to_time.to_i : 0 %>"
                 data-title="<%= menu.title %>">
            <%= check_box_tag "my_menu_ids[]", menu.id, false, class: "peer hidden menu-checkbox" %>
            <div class="px-4 py-2.5 rounded-xl bg-white shadow-sm border-2 border-transparent transition-all duration-200 
                    hover:shadow-md 
                    peer-checked:border-[#f69a6c]/50 peer-checked:border-1 peer-checked:bg-[#f69a6c]/10">
              <div class="flex items-center">
                <span class="text-sm sm:text-base font-medium text-gray-600 whitespace-nowrap
                         underline underline-offset-[-5px] decoration-10
                         <%= genre_underline_class(menu) %> 
                         group-has-[:checked]:font-bold group-has-[:checked]:no-underline transition-all">
                  <%= menu.title %>
                </span>
              </div>
            </div>
            <span class="absolute -top-2 -right-1 text-[#f69a6c] text-xl font-bold
                     pointer-events-none opacity-0 scale-75 transition-all duration-200
                     peer-checked:opacity-100 peer-checked:scale-120 z-30">
              ✓
            </span>
          </label>
        <% end %>
      </div>
    </div>
    <div class="pt-6 flex justify-center gap-4 page-section page-delay-4">
      <%= submit_tag "決定", class: "action-primary" %>
      <%= link_to home_path, class: "nav-back-button" do %>
        ← ホーム
      <% end %>
    </div>
  <% end %>
  <%= turbo_frame_tag "modal", class: "page-section page-delay-4" %>
</div>