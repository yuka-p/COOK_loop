<% content_for :title, "マイメニュー一覧" %>
<div class="max-w-3xl mx-auto mt-8">
  <div class="card bg-base-100 shadow px-4 md:px-8 py-4 max-w-[330px] md:max-w-2xl mx-auto page-section page-delay-1">
    <%= form_with url: my_menus_path, method: :get, local: true, id: "filterForm" do |f| %>
      <%= hidden_field_tag :genre, params[:genre] || "all", id: "genreInput" %>
      <%= hidden_field_tag :tag_ids, params[:tag_ids], id: "tagIdsInput" %>
      <div class="max-w-4xl mx-auto space-y-4">
        <div class="flex flex-col md:flex-row md:items-center gap-4">
          <div class="flex-1">
            <div id="genreFilters" class="flex flex-wrap gap-2">
              <button
              class="btn btn-sm genre-filter-button
                     bg-[#bebbf7]/40 text-gray-700 border border-[#bebbf7] hover:bg-[#bebbf7]/60"
              data-genre="all"
              type="button">
                すべて
              </button>
              <% genre_keys = MyMenu.genres.keys %>
              <% genre_keys.first(4).each do |genre| %>
                <button
                class="btn btn-sm genre-filter-button <%= genre_button_class(genre) %>"
                data-genre="<%= genre %>"
                type="button">
                  <%= MyMenu.genres_i18n[genre] %>
                  <span id="count-<%= genre %>" class="ml-1 hidden text-xs font-bold bg-primary text-white rounded-full px-1.5"></span>
                </button>
              <% end %>
              <div class="flex items-center justify-between w-full md:w-auto gap-2">
                <% genre_keys.drop(4).each do |genre| %>
                  <button
                  class="btn btn-sm genre-filter-button <%= genre_button_class(genre) %>"
                  data-genre="<%= genre %>"
                  type="button">
                    <%= MyMenu.genres_i18n[genre] %>
                    <span id="count-<%= genre %>" class="ml-1 hidden text-xs font-bold bg-primary text-white rounded-full px-1.5"></span>
                  </button>
                <% end %>
                <div class="md:hidden flex-none">
                  <%= f.select :sort,
                      options_for_select(
                        [
                          ["新しい順", "created_desc"],
                          ["最近作っていない順", "last_cooked_desc"],
                          ["50音順", "title_asc"],
                        ],
                        params[:sort]
                      ),
                      {},
                      { class: "select select-bordered select-sm w-[180px] text-sm focus:outline-none js-sort-select" }
                  %>
                </div>
              </div>
            </div>
          </div>
          <div class="hidden md:block md:w-56">
            <%= f.select :sort,
            options_for_select(
              [
                ["新しい順", "created_desc"],
                ["最近作っていない順", "last_cooked_desc"],
                ["50音順", "title_asc"],
              ],
              params[:sort]
            ),
            {},
            { class: "select select-bordered w-full", id: "sortSelect" }
          %>
          </div>
        </div>
        <% if @tags.present? %>
          <div id="tagFilters" class="flex gap-2 flex-wrap pt-2">
            <% @tags.each do |tag| %>
              <button type="button" class="tag-filter-button" data-tag-id="<%= tag.id %>">
                <%= tag.name %>
              </button>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
  <div class="bg-[#faf0e6] p-4 sm:p-8 rounded-2xl my-6 space-y-4 sm:space-y-6 page-section page-delay-2">
    <div class="grid grid-cols-2 sm:flex sm:flex-row gap-3 sm:gap-6 justify-center items-center mb-6 sm:mb-10 mt-4 sm:mt-6 max-w-[280px] sm:max-w-none mx-auto">
      <%= link_to "＋ 新規作成", new_my_menu_path,
      class: "action-primary col-span-2 py-2.5 sm:py-3 px-6 text-sm sm:text-base flex items-center justify-center w-full sm:w-auto max-w-[140px] sm:max-w-none mx-auto sm:mx-0" %>
      <%= link_to "定番から選ぶ",
      master_menus_path(select: true),
      class: "action-outline py-2 sm:py-3 px-1 sm:px-6 text-[12px] sm:text-base flex items-center justify-center w-full sm:w-auto max-w-[130px] sm:max-w-none ml-auto sm:ml-0" %>
      <%= link_to "レシピを探す",
      recipes_path,
      class: "action-outline py-2 sm:py-3 px-1 sm:px-6 text-[12px] sm:text-base flex items-center justify-center w-full sm:w-auto max-w-[130px] sm:max-w-none mr-auto sm:mr-0" %>
    </div>
    <%= form_with url: my_menus_path,
        method: :get,
        local: true,
        id: "filterForm",
        class: "mb-8" do |f| %>
      <div class="max-w-md mx-auto px-4">
        <div class="relative mb-3">
          <%= f.text_field :keyword,
              value: params[:keyword],
              placeholder: "メニュー名や材料で検索",
              class: "input w-full rounded-full border border-gray-200 bg-white focus:bg-white focus:border-[#98b3a0] focus:outline-none transition-all pl-6 pr-28 py-6 text-gray-600 shadow-sm",
              style: "font-size: 16px;" %>
          <%= f.submit "検索",
              class: "absolute right-1.5 top-1/2 -translate-y-1/2 
                      btn rounded-full border-none text-white px-6 font-light h-[calc(100%-12px)] min-h-0 z-10",
              style: "background-color: #98b3a0; font-size: 14px;" %>
        </div>
        <div class="flex justify-end items-center px-2">
          <label class="cursor-pointer label p-0 gap-2">
            <%= f.check_box :include_ingredients, 
                { checked: params[:include_ingredients] == "1", 
                  class: "checkbox checkbox-sm rounded-md border-gray-300", 
                  style: "--chkbg: #98b3a0; --chkb: #98b3a0;" }, "1", "0" %>
            <span class="label-text text-gray-500" style="font-size: 12px;">材料も含める</span>
          </label>
        </div>
      </div>
    <% end %>
    <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 gap-5 items-start page-section page-delay-3">
      <% @my_menus.each do |menu| %>
        <div class="relative bg-white rounded-r-xl rounded-l-md px-3 py-1.5 h-fit
                transition-all duration-300 
                hover:shadow-md hover:-translate-y-0.5
                active:scale-[0.98]
                border-l-[10px] shadow-sm
                <%= genre_border_class(menu).gsub('border-6', '') %>">
          <div class="flex justify-between items-center gap-1">
            <%= link_to my_menu_path(menu), class: "flex-1 block min-w-0" do %>
              <p class="text-[14px] sm:text-[15px] font-medium text-gray-800 leading-tight">
                <%= menu.title %>
              </p>
            <% end %>
            <div class="shrink-0 -mr-1">
              <%= link_to edit_my_menu_path(menu),
                class: "p-1.5 text-gray-300 hover:text-gray-500 transition-colors flex items-center",
                data: { turbo: false } do %>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-pencil"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
  <div class="flex justify-center page-section page-delay-4">
    <%= link_to home_path, class: "nav-back-button" do %>
      ← ホーム
    <% end %>
  </div>
